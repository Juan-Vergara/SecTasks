# === Configuración del Servidor para Docker ===
PORT=3000
NODE_ENV=production

# === Base de Datos MySQL (Docker) ===
# Estos valores deben coincidir con docker-compose.yml
DB_HOST=db
DB_PORT=3306
DB_USER=sectask
DB_PASSWORD=sectaskpass
DB_NAME=sectask_db

# === JWT ===
JWT_SECRET=CAMBIAR_POR_UNA_CLAVE_SEGURA
JWT_EXPIRES_IN=24h

# === Token de Reset de Contraseña ===
RESET_TOKEN_EXPIRES_MINUTES=10

# === reCAPTCHA ===
# Obtén tus claves en: https://www.google.com/recaptcha/admin
RECAPTCHA_SECRET_KEY=TU_CLAVE_SECRETA_DE_RECAPTCHA_AQUI
